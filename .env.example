# Copy the values you need into your shell, direnv, or process manager.
# The app documents these variables, but does not load .env files automatically.

# Runtime workspace
MIN_KB_STORE_ROOT=/absolute/path/to/min-kb-store
MIN_KB_APP_PORT=8787
MIN_KB_APP_ORCHESTRATOR_TMUX_SESSION=min-kb-app-orchestrator

# CLI target
MIN_KB_APP_RUNTIME_URL=http://localhost:8787

# Gemini runtime provider (preferred names first, then legacy SDK fallbacks)
# MIN_KB_APP_GEMINI_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# MIN_KB_APP_GEMINI_USE_VERTEXAI=true
# GOOGLE_GENAI_USE_VERTEXAI=true
# MIN_KB_APP_GEMINI_PROJECT=
# GOOGLE_CLOUD_PROJECT=
# MIN_KB_APP_GEMINI_LOCATION=
# GOOGLE_CLOUD_LOCATION=
# MIN_KB_APP_GEMINI_API_VERSION=
# MIN_KB_APP_GEMINI_MODEL=

# LM Studio runtime provider
# MIN_KB_APP_LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# MIN_KB_APP_LM_STUDIO_MODEL=
# LM_STUDIO_MODEL=
# MIN_KB_APP_LM_STUDIO_MODELS_TIMEOUT_MS=15000
# MIN_KB_APP_LM_STUDIO_CHAT_TIMEOUT_MS=600000
# MIN_KB_APP_LM_STUDIO_MAX_COMPLETION_TOKENS=8192
# LM_STUDIO_MAX_COMPLETION_TOKENS=8192

# Optional legacy scheduler email delivery for orchestrator runs
# MIN_KB_APP_SMTP_HOST=
# MIN_KB_APP_SMTP_PORT=587
# MIN_KB_APP_SMTP_SECURE=false
# MIN_KB_APP_SMTP_USER=
# MIN_KB_APP_SMTP_PASS=
# MIN_KB_APP_SMTP_FROM=
# MIN_KB_APP_SMTP_REPLY_TO=

# Web build overrides
# VITE_API_BASE_URL=
# VITE_BASE_PATH=/
